# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=makros
DB_USER=postgres
DB_PASSWORD=
DB_SSL=
DB_PARAMS=

# Auth — omit all three to run without authentication
AUTH_USERNAME=
AUTH_PASSWORD=
AUTH_SECRET=

# Demo mode (Vercel only, optional)
APP_ENV=                 # set to "demo" to enable daily DB reseeds
DEMO_DB_NAME=            # database name to reseed in demo mode
CRON_SECRET=             # secret for the Vercel cron endpoint that triggers the reseed
